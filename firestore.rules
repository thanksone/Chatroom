rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function roomPath(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function isRoomMember(roomId) {
      return signedIn()
        && exists(roomPath(roomId))
        && request.auth.uid in get(roomPath(roomId)).data.members;
    }

	function isDirectRoom(roomId) {
	  return get(roomPath(roomId)).data.members is list
		&& get(roomPath(roomId)).data.members.size() == 2
		&& get(roomPath(roomId)).data.type != "group";
	}

	function blockedInRoom(roomId) {
	  return get(roomPath(roomId)).data.blockedBy is list
		&& get(roomPath(roomId)).data.blockedBy.size() > 0;
	}

	function canSendToRoom(roomId) {
	  return !isDirectRoom(roomId) || !blockedInRoom(roomId);
	}

    match /users/{uid} {
      allow create: if isSelf(uid);
      allow read: if signedIn();
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    match /rooms/{roomId} {
      allow create: if signedIn()
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members;

      allow read: if signedIn()
        && request.auth.uid in resource.data.members;

      allow update: if signedIn()
        && request.auth.uid in resource.data.members;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isRoomMember(roomId);

        allow create: if isRoomMember(roomId)
          && canSendToRoom(roomId)
          && request.resource.data.sender == request.auth.uid;

        allow update: if isRoomMember(roomId);

        allow delete: if false;
      }
    }
  }
}
