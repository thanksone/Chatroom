rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function roomPath(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function isRoomMember(roomId) {
      return signedIn()
        && exists(roomPath(roomId))
        && request.auth.uid in get(roomPath(roomId)).data.members;
    }

    function hasBlocked(blockerUid, blockedUid) {
      return exists(userPath(blockerUid))
        && get(userPath(blockerUid)).data.blockedUsers is list
        && blockedUid in get(userPath(blockerUid)).data.blockedUsers;
    }

    function isDirectRoom(roomId) {
      return get(roomPath(roomId)).data.members is list
        && get(roomPath(roomId)).data.members.size() == 2
        && get(roomPath(roomId)).data.type != "group";
    }

    function otherDirectMember(roomId) {
      return get(roomPath(roomId)).data.members[0] == request.auth.uid
        ? get(roomPath(roomId)).data.members[1]
        : get(roomPath(roomId)).data.members[0];
    }

    function canSendToRoom(roomId) {
      return !isDirectRoom(roomId)
        || (
          !hasBlocked(request.auth.uid, otherDirectMember(roomId))
          && !hasBlocked(otherDirectMember(roomId), request.auth.uid)
        );
    }

    match /users/{uid} {
      allow create: if isSelf(uid);
      allow read: if signedIn();
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    match /rooms/{roomId} {
      allow create: if signedIn()
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members;

      allow read: if signedIn()
        && request.auth.uid in resource.data.members;

      allow update: if signedIn()
        && request.auth.uid in resource.data.members;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isRoomMember(roomId);

        allow create: if isRoomMember(roomId)
          && canSendToRoom(roomId)
          && request.resource.data.sender == request.auth.uid;

        allow update: if isRoomMember(roomId);

        allow delete: if false;
      }
    }
  }
}
